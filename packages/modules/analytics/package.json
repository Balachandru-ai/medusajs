{
  "name": "@medusajs/analytics",
  "version": "2.11.3",
  "description": "Medusa Analytics module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#loaders/*": {
      "types": "./dist/loaders/*.d.ts",
      "default": "./dist/loaders/*.js"
    },
    "#services/*": {
      "types": "./dist/services/*.d.ts",
      "default": "./dist/services/*.js"
    },
    "#types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__mocks__",
    "!dist/**/__fixtures__"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/medusajs/medusa",
    "directory": "packages/modules/analytics"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Medusa",
  "license": "MIT",
  "scripts": {
    "watch": "yarn run -T tsc --build --watch",
    "watch:test": "yarn run -T tsc --build tsconfig.spec.json --watch",
    "build": "yarn run -T rimraf dist && yarn run -T tsc --build",
    "test": "../../../node_modules/.bin/jest --bail --passWithNoTests --forceExit --testPathPattern=src",
    "test:integration": "../../../node_modules/.bin/jest --passWithNoTests --forceExit --testPathPattern=\"integration-tests/__tests__/.*\\.ts\""
  },
  "devDependencies": {
    "@medusajs/framework": "2.11.3",
    "@medusajs/test-utils": "2.11.3"
  },
  "peerDependencies": {
    "@medusajs/framework": "2.11.3"
  }
}
