{
  "name": "@medusajs/caching",
  "version": "2.11.3",
  "description": "Caching Module for Medusa",
  "main": "dist/index.js",
  "imports": {
    "#loaders/*": {
      "types": "./dist/loaders/*.d.ts",
      "default": "./dist/loaders/*.js"
    },
    "#providers/*": {
      "types": "./dist/providers/*.d.ts",
      "default": "./dist/providers/*.js"
    },
    "#services/*": {
      "types": "./dist/services/*.d.ts",
      "default": "./dist/services/*.js"
    },
    "#types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "#utils/*": {
      "types": "./dist/utils/*.d.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/medusajs/medusa",
    "directory": "packages/modules/caching"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__mocks__",
    "!dist/**/__fixtures__"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Medusa",
  "license": "MIT",
  "scripts": {
    "watch": "yarn run -T tsc --build --watch",
    "watch:test": "yarn run -T tsc --build tsconfig.spec.json --watch",
    "build": "yarn run -T rimraf dist && yarn run -T tsc --build",
    "test": "../../../node_modules/.bin/jest --passWithNoTests --bail --forceExit --testPathPattern=src",
    "test:integration": "../../../node_modules/.bin/jest --passWithNoTests --forceExit --testPathPattern=\"integration-tests/__tests__/.*\\.ts\""
  },
  "devDependencies": {
    "@medusajs/framework": "2.11.3",
    "@medusajs/test-utils": "2.11.3",
    "awilix": "^8.0.1"
  },
  "peerDependencies": {
    "@medusajs/framework": "2.11.3",
    "awilix": "^8.0.1"
  },
  "dependencies": {
    "fast-json-stable-stringify": "^2.1.0",
    "node-cache": "^5.1.2",
    "xxhash-wasm": "^1.1.0"
  }
}
