{
  "name": "@medusajs/link-modules",
  "version": "2.11.3",
  "description": "Medusa Default Link Modules Package and Definitions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#definitions/*": {
      "types": "./dist/definitions/*.d.ts",
      "default": "./dist/definitions/*.js"
    },
    "#definitions/readonly/*": {
      "types": "./dist/definitions/readonly/*.d.ts",
      "default": "./dist/definitions/readonly/*.js"
    },
    "#initialize/*": {
      "types": "./dist/initialize/*.d.ts",
      "default": "./dist/initialize/*.js"
    },
    "#loaders/*": {
      "types": "./dist/loaders/*.d.ts",
      "default": "./dist/loaders/*.js"
    },
    "#migration/*": {
      "types": "./dist/migration/*.d.ts",
      "default": "./dist/migration/*.js"
    },
    "#migrations/*": {
      "types": "./dist/migrations/*.d.ts",
      "default": "./dist/migrations/*.js"
    },
    "#repositories/*": {
      "types": "./dist/repositories/*.d.ts",
      "default": "./dist/repositories/*.js"
    },
    "#services/*": {
      "types": "./dist/services/*.d.ts",
      "default": "./dist/services/*.js"
    },
    "#types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "#utils/*": {
      "types": "./dist/utils/*.d.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__mocks__",
    "!dist/**/__fixtures__"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/medusajs/medusa",
    "directory": "packages/modules/link-modules"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Medusa",
  "license": "MIT",
  "scripts": {
    "watch": "yarn run -T tsc --build --watch",
    "watch:test": "yarn run -T tsc --build tsconfig.spec.json --watch",
    "prepare": "cross-env NODE_ENV=production yarn run build",
    "build": "yarn run -T rimraf dist && yarn run -T tsc --build",
    "test": "../../../node_modules/.bin/jest --passWithNoTests --bail --forceExit --testPathPattern=src",
    "test:integration": "../../../node_modules/.bin/jest --passWithNoTests --forceExit --testPathPattern=\"integration-tests/__tests__/.*\\.ts\""
  },
  "devDependencies": {
    "@medusajs/framework": "2.11.3",
    "@medusajs/test-utils": "2.11.3"
  },
  "peerDependencies": {
    "@medusajs/framework": "2.11.3"
  }
}
